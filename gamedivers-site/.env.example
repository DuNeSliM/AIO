# Backend API URL (adjust to your backend location)
# Default is /api (same-origin). Set a full URL only when you explicitly need cross-origin calls.
VITE_API_BASE=/api

# Dev-only Vite proxy target used for /api -> backend rewriting.
VITE_DEV_API_PROXY_TARGET=http://localhost:8080

# Optional dev fallback JWT for protected API calls (Steam, ITAD, launch, sync).
# Prefer storing a user access token in browser storage via your auth flow.
VITE_AUTH_ACCESS_TOKEN=
# Optional alias supported by the frontend:
# VITE_AUTH_TOKEN=

# Enable dev/testing credit cheat controls in Missions page.
# Accepted truthy values: true, 1, yes, on
VITE_ENABLE_CREDIT_CHEAT=false

# Optional: enable web fallback call for GOG library endpoint.
# Keep false for production web deployments unless your backend actually implements it.
VITE_ENABLE_WEB_GOG_LIBRARY=false

# Optional: base URL used by website download links for desktop installers.
# If unset, links fall back to the repository releases page.
# VITE_DESKTOP_DOWNLOAD_BASE_URL=https://github.com/DuNeSliM/AIO/releases/download/desktop-v2026.03.04-1
# Optional: release tag for direct asset links when base URL is not set.
# VITE_DESKTOP_RELEASE_TAG=desktop-v2026.03.04-1

# Set to true when running in Tauri
# VITE_TAURI=true
